{
  "name": "inseme-monorepo",
  "private": false,
  "version": "1.0.0",
  "description": "Monorepo for Inseme and Platform Citoyenne",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "inseme:dev": "pnpm --filter @inseme/app-inseme run dev",
    "inseme:backend": "node scripts/check-tunnel.js && netlify dev --cwd apps/inseme --port 8888",
    "platform:dev": "pnpm run dev --filter platform",
    "platform:backend": "node scripts/check-tunnel.js && netlify dev --cwd apps/platform",
    "cyrnea:dev": "pnpm --filter @inseme/app-cyrnea run dev",
    "cyrnea:all": "turbo run @inseme/app-cyrnea#dev @inseme/models#sovereign:dev platform#tunnel",
    "cyrnea:tunnel": "pnpm --filter platform run tunnel",
    "cyrnea:backend": "node scripts/check-tunnel.js && netlify dev --cwd apps/cyrnea",
    "sovereign:up": "pnpm --filter @inseme/models run sovereign:up",
    "sovereign:down": "pnpm --filter @inseme/models run sovereign:down",
    "sovereign:status": "pnpm --filter @inseme/models run sovereign:status",
    "compile:briques": "node packages/cop-host/scripts/compile-briques.js",
    "inseme:build": "pnpm --filter @inseme/app-inseme run build",
    "platform:build": "pnpm run build --filter platform",
    "cyrnea:build": "pnpm --filter @inseme/app-cyrnea run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "glob": "^11.0.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "turbo": "^2.7.3",
    "undici": "^7.18.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md}": "prettier --write"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "dotenv": "^17.2.3",
    "node-fetch": "^3.0.0"
  }
}
