{
  "name": "inseme-monorepo",
  "private": false,
  "version": "1.0.0",
  "description": "Monorepo for Inseme and Platform Citoyenne",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "inseme:dev": "npm run dev -w inseme",
    "inseme:backend": "netlify dev --cwd apps/inseme --port 8888",
    "platform:dev": "npm run dev -w platform",
    "platform:backend": "netlify dev --cwd apps/platform",
    "cyrnea:dev": "npm run dev -w cyrnea",
    "cyrnea:backend": "netlify dev --cwd apps/cyrnea",
    "compile:briques": "node packages/cop-host/scripts/compile-briques.js",
    "inseme:build": "npm run build -w inseme",
    "platform:build": "npm run build -w platform"
  },
  "devDependencies": {
    "glob": "^11.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "turbo": "^2.7.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  },
  "dependencies": {
    "lucide-react": "^0.562.0"
  }
}
